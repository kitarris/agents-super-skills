{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "deck-spec.schema.json",
  "title": "DeckSpec",
  "type": "object",
  "required": ["deck_title", "audience", "core_promise", "claim_spine", "slides"],
  "properties": {
    "deck_title": { "type": "string", "minLength": 1 },
    "audience": { "type": "string", "minLength": 1 },
    "core_promise": { "type": "string", "minLength": 1 },
    "output_dir": {
      "type": "string",
      "description": "Absolute artifact directory; must not be inside the skill directory."
    },
    "claim_spine": { "type": "array", "items": { "type": "string" }, "minItems": 3 },
    "visual_system": { "type": "object", "default": {} },
    "interaction_policy": { "type": "object", "default": {} },
    "control_policy": {
      "type": "string",
      "enum": ["visible-controls", "keyboard-only", "none"],
      "default": "visible-controls"
    },
    "geometry_policy": {
      "type": "object",
      "description": "Deck-wide frame contract for stable slide-to-slide geometry.",
      "properties": {
        "frame_contract": { "type": "string", "default": "fixed-stage-frame" },
        "required_slots": {
          "type": "array",
          "items": { "type": "string" },
          "default": ["stage", "title", "support", "content"]
        },
        "coordinate_delta_tolerance_px": { "type": "number", "minimum": 0, "default": 0 },
        "scroll_policy": {
          "type": "string",
          "enum": ["none", "content-zone", "document"],
          "default": "content-zone"
        }
      },
      "additionalProperties": true,
      "default": {}
    },
    "source_registry": { "type": "array", "items": { "type": "object" }, "default": [] },
    "slides": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "slide-spec.schema.json" }
    },
    "qa_gates": { "type": "array", "items": { "type": "string" }, "default": [] }
  },
  "additionalProperties": true
}
